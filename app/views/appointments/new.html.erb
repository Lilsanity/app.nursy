<div class="container my-5" style="max-width: 600px;">
  <h2>Demander un rendez-vous</h2>

  <%= form_with model: @appointment, local: true do |f| %>
    <%= f.hidden_field :nurse_id, value: @nurse.id %>

    <div class="mb-3">
      <%= f.label :availability_id, "Choisissez un créneau", class: "form-label" %>
      <%= f.collection_select :availability_id, @availabilities, :id, :start_time, { prompt: "Sélectionnez un horaire" }, { class: "form-control" } %>
    </div>

    <div class="mb-3">
      <%= f.label :care_type, "Type de soin", class: "form-label" %>
      <%= f.text_field :care_type, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :address, "Adresse du soin", class: "form-label" %>
      <%= f.text_field :address, class: "form-control", value: current_user.commune %>
    </div>

    <%= f.submit "Envoyer la demande", class: "btn btn-primary w-100 py-3" %>
  <% end %>
</div>