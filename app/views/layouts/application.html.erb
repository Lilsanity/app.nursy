<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App Nursy" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App Nursy">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand navbar-lewagon">
      <div class="container-fluid">
        <%= link_to "Nursy", root_path, class: "navbar-brand" %>

        <ul class="navbar-nav mx-auto">
          <li class="nav-item">
            <%= link_to "Accueil", root_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Recherche", nurses_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Profil", nurses_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Mon espace", my_space_path, class: "nav-link" %>
          </li>
        </ul>

        <ul class="navbar-nav ms-auto">
          <% if user_signed_in? %>
            <li class="nav-item d-flex align-items-center me-3">
              <%= "#{current_user.first_name} #{current_user.last_name}" %>
            </li>
            <li class="nav-item">
              <%= button_to "Se déconnecter", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary btn-sm" %>
            </li>
          <% else %>
            <li class="nav-item me-2">
              <%= link_to "Se connecter", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
            </li>
            <li class="nav-item">
              <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-primary btn-sm" %>
            </li>
          <% end %>
        </ul>
      </div>
    </nav>

    <% flash.each do |type, message| %>
      <div class="alert alert-<%= type == "notice" ? "success" : "danger" %>" role="alert">
        <%= message %>
      </div>
    <% end %>

    <%= yield %>
    <footer class="site-footer">
      <p>© 2026 Nursy — Tous droits réservés</p>
    </footer>
  </body>
</html>
